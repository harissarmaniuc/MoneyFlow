# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_tracker
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis (optional, for production)
REDIS_URL=redis://localhost:6379

# External Services (Phase 2+)
GOOGLE_VISION_API_KEY=your_google_vision_key
FIREBASE_STORAGE_BUCKET=your_firebase_bucket
SENDGRID_API_KEY=your_sendgrid_key
STRIPE_SECRET_KEY=your_stripe_key
FCM_SERVER_KEY=your_fcm_key

# CORS
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# Production only
# DATABASE_URL overrides individual DB_* vars when set (Railway / Heroku provide this automatically)
# Set NODE_ENV=production on your hosting platform
